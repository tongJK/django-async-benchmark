# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# PostgreSQL
DB_NAME=async_benchmark
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Benchmark config
# Set to "mock" to use local mock server (no internet needed)
# Set to "external" to use httpbin.org (default)
BENCHMARK_IO_MODE=mock
BENCHMARK_MOCK_DELAY=1.0
